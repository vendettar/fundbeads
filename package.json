{
  "name": "fundbeads",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check": "pnpm build:frontend && pnpm test:frontend",
    "test:frontend": "pnpm --dir frontend test:run",
    "design:generate": "node scripts/generate-design-theme.mjs",
    "design:lint": "designmd lint DESIGN.md",
    "design:export": "pnpm design:generate",
    "dev": "pnpm dev:frontend",
